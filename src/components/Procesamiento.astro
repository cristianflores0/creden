---
---

<section class="w-full bg-gray-100 py-16 mt-48" id="procesamiento">
  <!-- Header section with title and image -->
  <div class="w-11/12 mx-auto mb-12 py-12" style="background-image: url('/assets/images/Fondo Procesamiento.png'); background-size: cover; background-position: center;">
    <div class="flex gap-12 items-center">
      <div class="w-2/3 pl-12 pt-8">
        <h2 class="text-3xl mb-4 text-white creden-espaciado">PROCESAMIENTO 365</h2>
        <p class="text-white mb-6">Acreditación de cobros con tarjeta en el día, los 365 días del año.</p>
      </div>
      <div class="w-1/2">
        <!-- Image will be added here -->
      </div>
    </div>
  </div>

  <!-- Efficiency badge -->
  <div class="flex justify-center mb-4">
    <p class="text-gray-600 text-center">Pagos rápidos y seguros en transacciones nacionales e internacionales con</p>
  </div>
  <div class="flex justify-center mb-12">
    <div class="bg-blue-500/40 text-white px-6 rounded-full flex items-center relative">
      <span class="bg-blue-500 text-xl px-8 py-1 rounded-full -ml-6 creden-poppins">99,9%</span>
      <span class="text-lg ml-2 creden-poppins">Eficiencia operativa</span>
    </div>
  </div>

  <!-- Features grid -->
  <div class="px-8 mb-16">
    <div class="grid md:grid-cols-2 gap-6">
      <div class="bg-white p-8 rounded-lg shadow-sm flex gap-6">
        <div class="shrink-0">
          <img src="/assets/icons/Procesamiento.png" alt="Procesamiento" class="w-12 h-12" loading="lazy">
        </div>
        <div>
          <p class="text-gray-700">Procesamiento de transacciones nacionales e internacionales.</p>
        </div>
      </div>

      <div class="bg-white p-8 rounded-lg shadow-sm flex gap-6">
        <div class="shrink-0">
          <img src="/assets/icons/Monitoreo.png" alt="Monitoreo" class="w-12 h-12" loading="lazy">
        </div>
        <div>
          <p class="text-gray-700">Monitoreo en tiempo real de compras y operaciones.</p>
        </div>
      </div>

      <div class="bg-white p-8 rounded-lg shadow-sm flex gap-6">
        <div class="shrink-0">
          <img src="/assets/icons/Scoring.png" alt="Scoring" class="w-12 h-12" loading="lazy">
        </div>
        <div>
          <p class="text-gray-700">Scoring crediticio inteligente para evaluar solvencia y riesgo.</p>
        </div>
      </div>

      <div class="bg-white p-8 rounded-lg shadow-sm flex gap-6">
        <div class="shrink-0">
          <img src="/assets/icons/Gestion.png" alt="Gestión" class="w-12 h-12" loading="lazy">
        </div>
        <div>
          <p class="text-gray-700">Gestión y autorización de pagos con máxima eficiencia.</p>
        </div>
      </div>
    </div>
  </div>

  <!-- Certifications/Logos section -->
  <div class="px-8 py-6 mb-2">
    <div class="w-11/12 mx-auto mb-8 flex justify-center items-center gap-10 flex-wrap">
      <img src="/assets/icons/PCI dss.png" alt="PCI" class="h-12" loading="lazy">
      <img src="/assets/icons/Isae.png" alt="ISAE" class="h-12" loading="lazy">
      <img src="/assets/icons/CNBV.png" alt="CNBV" class="h-12" loading="lazy">
      <img src="/assets/icons/SAT.png" alt="SAT" class="h-12" loading="lazy">
      <img src="/assets/icons/Banco Central Republica Argentina.png" alt="Argentina" class="h-12" loading="lazy">
      <img src="/assets/icons/Banco Central del Uruguay.png" alt="Uruguay" class="h-12" loading="lazy">
      <img src="/assets/icons/Banco Central del Ecuador.png" alt="Ecuador" class="h-12" loading="lazy">
    </div>
    <p class="text-center text-gray-600 text-sm mb-8">Somos una compañía regulada por los bancos centrales y entes reguladores en los países donde operamos.</p>
  </div>

  <!-- Footer cards -->
  <div class="px-8">
    <div class="grid md:grid-cols-4 gap-6">
      <div class="text-white p-8 rounded-lg text-center" style="background-color: #1e1e1d;">
        <h3>Cumplimiento de normativas</h3>
      </div>
      <div class="text-white p-8 rounded-lg text-center" style="background-color: #1e1e1d;">
        <h3>Certificaciones locales e internacionales</h3>
      </div>
      <div class="text-white p-8 rounded-lg text-center px-20" style="background-color: #1e1e1d;">
        <h3>Planes de contingencia</h3>
      </div>
      <div class="text-white p-8 rounded-lg text-center px-18 bg-creden-green">
        <h3>Resguardo de datos sensibles</h3>
      </div>
    </div>
  </div>
</section>
