---
---

<section class="w-full bg-gray-100 py-16" id="adquirencia">
  <!-- Header section with title and image -->
  <div class="w-11/12 mx-auto mb-12 py-12" style="background-image: url('/assets/images/Adquirencia fondo.png'); background-size: cover; background-position: center;">
    <div class="flex gap-12 items-center">
      <div class="w-2/3 pl-12 py-12 flex flex-col justify-center">
        <h2 class="text-4xl text-white creden-espaciado">ADQUIRENCIA</h2>
      </div>
      <div class="w-1/2">
        <!-- Image will be added here -->
      </div>
    </div>
  </div>

  <!-- Description text -->
  <div class="flex justify-center mb-12">
    <p class="text-gray-600 text-center px-8 max-w-6xl">Toda la información clave en tiempo real sobre ventas, ingresos y movimientos de cuenta, para que los comercios puedan decidir mejor, más rápido y con total control desde una plataforma integral.</p>
  </div>

  <!-- Features grid -->
  <div class="px-8 mb-16">
    <div class="grid md:grid-cols-2 gap-6">
      <!-- Card 1: Dashboard -->
      <div class="bg-white rounded-lg shadow-sm overflow-hidden">
        <div class="flex items-stretch">
          <div class="w-1/3 flex items-center justify-center p-4">
            <img src="/assets/images/Dashboard.png" alt="Dashboard" class="h-40 object-contain">
          </div>
          <div class="w-2/3 p-8 flex flex-col justify-center">
            <h3 class="text-lg font-semibold mb-4 uppercase creden-azul">Dashboard</h3>
            <ul class="space-y-2" style="color: #606060;">
              <li class="flex items-start">
                <span class="mr-3" style="color: #606060;">•</span>
                <span>Visualización de movimientos, acreditaciones y pendientes</span>
              </li>
              <li class="flex items-start">
                <span class="mr-3" style="color: #606060;">•</span>
                <span>Reportería mensual sobre ventas</span>
              </li>
              <li class="flex items-start">
                <span class="mr-3" style="color: #606060;">•</span>
                <span>Notificaciones push sobre las operaciones del comercio</span>
              </li>
            </ul>
          </div>
        </div>
      </div>

      <!-- Card 2: Billetera virtual -->
      <div class="bg-white rounded-lg shadow-sm overflow-hidden">
        <div class="flex items-stretch">
          <div class="w-1/3 flex items-center justify-center p-4">
            <img src="/assets/images/Billetera Virtual.png" alt="Billetera Virtual" class="h-40 object-contain">
          </div>
          <div class="w-2/3 p-8 flex flex-col justify-center">
            <h3 class="text-lg font-semibold mb-4 uppercase creden-azul">Billetera virtual</h3>
            <ul class="space-y-2" style="color: #606060;">
              <li class="flex items-start">
                <span class="mr-3" style="color: #606060;">•</span>
                <span>Pago a proveedores</span>
              </li>
              <li class="flex items-start">
                <span class="mr-3" style="color: #606060;">•</span>
                <span>Pago de servicios y recargas</span>
              </li>
              <li class="flex items-start">
                <span class="mr-3" style="color: #606060;">•</span>
                <span>Retiro de efectivo en cajeros</span>
              </li>
              <li class="flex items-start">
                <span class="mr-3" style="color: #606060;">•</span>
                <span>Programa de lealtad para clientes</span>
              </li>
            </ul>
          </div>
        </div>
      </div>

      <!-- Card 3: POS -->
      <div class="bg-white rounded-lg shadow-sm overflow-hidden min-h-[220px]">
        <div class="flex items-stretch h-full">
          <div class="w-1/3 flex items-center justify-center p-4">
            <img src="/assets/images/POS.png" alt="POS" class="h-40 object-contain">
          </div>
          <div class="w-2/3 p-8 flex flex-col justify-center mt-3">
            <h3 class="text-lg font-semibold mb-4 uppercase creden-azul">POS</h3>
            <ul class="space-y-2" style="color: #606060;">
              <li class="flex items-start">
                <span class="mr-3" style="color: #606060;">•</span>
                <span>Aceptación de todos los medios de pago (débito, crédito y prepaga)</span>
              </li>
              <li class="flex items-start">
                <span class="mr-3" style="color: #606060;">•</span>
                <span>Integración en tiendas físicas y online</span>
              </li>
            </ul>
          </div>
        </div>
      </div>

      <!-- Card 4: Medios de pago -->
      <div class="bg-white rounded-lg shadow-sm overflow-hidden">
        <div class="flex items-stretch">
          <div class="w-1/3 flex items-center justify-center p-4">
            <img src="/assets/images/Medios de pago.png" alt="Medios de pago" class="h-40 object-contain">
          </div>
          <div class="w-2/3 p-8 flex flex-col justify-center">
            <h3 class="text-lg font-semibold mb-4 uppercase creden-azul">Medios de pago</h3>
            <ul class="space-y-2" style="color: #606060;">
              <li class="flex items-start">
                <span class="mr-3" style="color: #606060;">•</span>
                <span>Pagos con QR interoperables y de cobro inmediato</span>
              </li>
              <li class="flex items-start">
                <span class="mr-3" style="color: #606060;">•</span>
                <span>Circuitos closed-loop</span>
              </li>
              <li class="flex items-start">
                <span class="mr-3" style="color: #606060;">•</span>
                <span>Links de pago personalizados y compartibles</span>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Text and image section -->
  <div class="px-8 mb-16">
    <div class="flex gap-8 items-center">
      <div class="w-3/5 pl-18">
        <p style="color: #606060;" class="text-base leading-relaxed">Transferencias instantáneas, pagos QR y NFC; garantizamos que cada pago sea dinámico y seguro, conectando comercios, bancos y usuarios en segundos.</p>
      </div>
      <div class="w-2/5">
        <img src="/assets/images/Imagen Transferencias.png" alt="Transferencias" class="w-full rounded-lg">
      </div>
    </div>
  </div>

  <!-- Características section -->
  <div class="px-8 mb-16">
    <div class="py-16" style="background-image: url('/assets/images/Fondo Adquirencia Caracteristicas.png'); background-size: cover; background-position: center; border-radius: 1rem;">
      <div class="flex gap-12 items-center px-12">
      <!-- Left side: Boxes -->
      <div class="w-1/2 space-y-4">
        <div class="text-white p-6 border-4 border-creden-azul bg-creden-azul creden-box-rounded">
          <p class="text-lg">Bill payment, recargas telefónicas y transferencias</p>
        </div>
        <div class="text-white p-6 border-4 border-creden-azul bg-creden-azul creden-box-rounded">
          <p class="text-lg">Acreditación en cuenta CVU de comercio</p>
        </div>
        <div class="text-white p-6 border-4 border-creden-azul bg-creden-azul creden-box-rounded">
          <p class="text-lg">Pago a proveedores, pagarés y dispersión de fondos</p>
        </div>
        <div class="text-white p-6 border-4 border-creden-azul bg-creden-azul creden-box-rounded">
          <p class="text-lg">Crédito, débito y prepago</p>
        </div>
      </div>

      <!-- Right side: Title and text -->
      <div class="w-1/2">
        <h3 class="text-3xl text-white mb-6">Una billetera que simplifica</h3>
        <p class="text-white text-base leading-relaxed">Nuestras billeteras marca blanca son una alternativa de circuito cerrado, pensada para agilizar los procesos de cobranza, simplificar la conciliación y lograr un rendimiento permanente de fondos.</p>
      </div>
    </div>
  </div>

  <!-- Plain text section with logos -->
  <div class="px-8 mb-12">
    <div class="px-8 py-8">
      <p class="text-gray-600 text-center px-8 mb-8">Nuestra propuesta permite a distintas entidades financieras: bancos, fintechs, retailers, uniones de crédito y cooperativas, entre otras, acceder a soluciones de emisión, procesamiento y digitalización, 100% integrables vía APIs o llave en mano.</p>
      
      <!-- Logos section - distributed across full width -->
      <div class="flex justify-between items-center gap-4">
        <img src="/assets/images/vale.png" alt="Si vale" class="h-12 max-w-[90px] object-contain">
        <img src="/assets/images/Broxel.png" alt="Broxel" class="h-12 max-w-[90px] object-contain">
        <img src="/assets/images/Bit2me.png" alt="Bit2me" class="h-12 max-w-[90px] object-contain">
        <img src="/assets/images/Gate.png" alt="Gate.io" class="h-12 max-w-[90px] object-contain">
        <img src="/assets/images/Spendmex.png" alt="Spendmex" class="h-12 max-w-[90px] object-contain">
        <img src="/assets/images/Western Union.png" alt="Western Union" class="h-12 max-w-[90px] object-contain">
        <img src="/assets/images/Financoop.png" alt="Financoop" class="h-12 max-w-[90px] object-contain">
        <img src="/assets/images/Binance.png" alt="Binance" class="h-12 max-w-[90px] object-contain">
        <img src="/assets/images/Triumph.png" alt="Triumph" class="h-12 max-w-[90px] object-contain">
      </div>
    </div>
  </div>
</section>
