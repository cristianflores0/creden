---
import { Image } from 'astro:assets';
import tarjetas from '../assets/icons/Tarjetas.png';
import paises from '../assets/icons/Paises.png';
import transacciones from '../assets/icons/Transacciones.png';
import dataCenter from '../assets/icons/Data Center.png';
import oficinas from '../assets/icons/Oficinas.png';
import fondoNuestraPresencia from '../assets/images/Fondo Nuestra Presencia.png';
---

<!-- Statistics Cards Section -->
<section class="w-full text-white px-8 py-20" style={`background-image: url('${fondoNuestraPresencia.src}'); background-size: cover; background-position: center; background-repeat: no-repeat; background-color: #1e1e1d;`}>
  
  <!-- Title -->
  <div class="mb-16 text-center">
    <h2 class="text-5xl font-bold">Nuestra presencia</h2>
  </div>
  
  <!-- Statistics Grid -->
  <div class="grid grid-cols-3 gap-8">
    
    <!-- Card 1: +18M tarjetas -->
    <div class="p-8 backdrop-blur-sm" style="background-color: rgba(60, 60, 60, 0.6); border: 1px solid rgba(100, 100, 100, 0.3); clip-path: polygon(0 0, calc(100% - 25px) 0, 100% 25px, 100% 100%, 25px 100%, 0 calc(100% - 25px)); display: grid; grid-template-columns: 1fr auto; grid-template-rows: auto 1fr; gap: 1rem; min-height: 200px;">
      <Image src={tarjetas} alt="Tarjeta" class="w-12 h-12 shrink-0" style="grid-column: 2; grid-row: 1;" />
      <p class="text-5xl font-bold" style="grid-column: 1; grid-row: 1 / -1; align-self: center;">+18<span class="text-3xl">M</span></p>
      <p class="text-sm text-gray-300" style="grid-column: 2; grid-row: 2; align-self: end;">de tarjetas procesadas en la región</p>
    </div>
    
    <!-- Card 2: 15 países -->
    <div class="p-8 backdrop-blur-sm" style="background-color: rgba(60, 60, 60, 0.6); border: 1px solid rgba(100, 100, 100, 0.3); clip-path: polygon(0 0, calc(100% - 25px) 0, 100% 25px, 100% 100%, 25px 100%, 0 calc(100% - 25px)); display: grid; grid-template-columns: 1fr auto; grid-template-rows: auto 1fr; gap: 1rem; min-height: 200px;">
      <Image src={paises} alt="Globo" class="w-12 h-12 shrink-0" style="grid-column: 2; grid-row: 1;" />
      <p class="text-5xl font-bold" style="grid-column: 1; grid-row: 1 / -1; align-self: center;">15</p>
      <p class="text-sm text-gray-300" style="grid-column: 2; grid-row: 2; align-self: end;">países de LATAM donde estamos homologados</p>
    </div>
    
    <!-- Card 3: +170M transacciones -->
    <div class="p-8 backdrop-blur-sm" style="background-color: rgba(60, 60, 60, 0.6); border: 1px solid rgba(100, 100, 100, 0.3); clip-path: polygon(0 0, calc(100% - 25px) 0, 100% 25px, 100% 100%, 25px 100%, 0 calc(100% - 25px)); display: grid; grid-template-columns: 1fr auto; grid-template-rows: auto 1fr; gap: 1rem; min-height: 200px;">
      <Image src={transacciones} alt="Monitor" class="w-12 h-12 shrink-0" style="grid-column: 2; grid-row: 1;" />
      <p class="text-5xl font-bold" style="grid-column: 1; grid-row: 1 / -1; align-self: center;">+170<span class="text-3xl">M</span></p>
      <p class="text-sm text-gray-300" style="grid-column: 2; grid-row: 2; align-self: end;">transacciones mensuales</p>
    </div>
    
    <!-- Card 4: +2B transacciones anuales -->
    <div class="p-8 backdrop-blur-sm" style="background-color: rgba(60, 60, 60, 0.6); border: 1px solid rgba(100, 100, 100, 0.3); clip-path: polygon(0 0, calc(100% - 25px) 0, 100% 25px, 100% 100%, 25px 100%, 0 calc(100% - 25px)); display: grid; grid-template-columns: 1fr auto; grid-template-rows: auto 1fr; gap: 1rem; min-height: 200px;">
      <Image src={transacciones} alt="Dinero" class="w-12 h-12 shrink-0" style="grid-column: 2; grid-row: 1;" />
      <p class="text-5xl font-bold" style="grid-column: 1; grid-row: 1 / -1; align-self: center;">+2<span class="text-3xl">B</span></p>
      <p class="text-sm text-gray-300" style="grid-column: 2; grid-row: 2; align-self: end;">de transacciones anuales</p>
    </div>
    
    <!-- Card 5: 4 data centers -->
    <div class="p-8 backdrop-blur-sm" style="background-color: rgba(60, 60, 60, 0.6); border: 1px solid rgba(100, 100, 100, 0.3); clip-path: polygon(0 0, calc(100% - 25px) 0, 100% 25px, 100% 100%, 25px 100%, 0 calc(100% - 25px)); display: grid; grid-template-columns: 1fr auto; grid-template-rows: auto 1fr; gap: 1rem; min-height: 200px;">
      <Image src={dataCenter} alt="Servidor" class="w-12 h-12 shrink-0" style="grid-column: 2; grid-row: 1;" />
      <p class="text-5xl font-bold" style="grid-column: 1; grid-row: 1 / -1; align-self: center;">4</p>
      <p class="text-sm text-gray-300" style="grid-column: 2; grid-row: 2; align-self: end;">data centers distribuidos por México, Estados Unidos y Argentina</p>
    </div>
    
    <!-- Card 6: 3 oficinas comerciales -->
    <div class="p-8 backdrop-blur-sm" style="background-color: rgba(60, 60, 60, 0.6); border: 1px solid rgba(100, 100, 100, 0.3); clip-path: polygon(0 0, calc(100% - 25px) 0, 100% 25px, 100% 100%, 25px 100%, 0 calc(100% - 25px)); display: grid; grid-template-columns: 1fr auto; grid-template-rows: auto 1fr; gap: 1rem; min-height: 200px;">
      <Image src={oficinas} alt="Edificio" class="w-12 h-12 shrink-0" style="grid-column: 2; grid-row: 1;" />
      <p class="text-5xl font-bold" style="grid-column: 1; grid-row: 1 / -1; align-self: center;">3</p>
      <p class="text-sm text-gray-300" style="grid-column: 2; grid-row: 2; align-self: end;">oficinas comerciales en Ecuador, México y Argentina</p>
    </div>
    
  </div>
  
</section>
