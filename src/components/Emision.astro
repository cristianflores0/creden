---
---

<section class="w-full bg-gray-100 py-16 mt-0" id="emision">
  <!-- Header section with title and image -->
  <div class="w-11/12 mx-auto mb-12 py-12" style="background-image: url('/assets/images/-Imagen Emisión-.png'); background-size: cover; background-position: center;">
    <div class="flex gap-12 items-center">
      <div class="w-2/3 pl-12 py-12 flex flex-col justify-center">
        <h2 class="text-4xl text-white" style="letter-spacing: 0.44em; font-family: 'Myriad Pro', sans-serif;">EMISIÓN</h2>
      </div>
      <div class="w-1/2">
        <!-- Image will be added here -->
      </div>
    </div>
  </div>

  <!-- Disclaimer text -->
  <div class="flex justify-center mb-12">
    <p class="text-gray-600 text-center px-8 max-w-6xl">Ofrecemos tarjetas físicas y/o virtuales bajo licencia Mastercard, Visa, Carnet o marca privada, con opción de BIN Sponsorship propio para que cada cliente gestione y administre según sus objetivos comerciales, y potencie el control de gus gastos.</p>
  </div>

  <!-- Features grid -->
  <div class="px-8 mb-16">
    <div class="grid md:grid-cols-2 gap-6">
      <div class="bg-white p-8 rounded-lg shadow-sm">
        <h3 class="text-lg text-gray-900 mb-3">Control y autonomía financiera</h3>
        <p class="text-gray-700">Asignación de fondos, límites y gestión de contracargos parametrizados</p>
      </div>

      <div class="bg-white p-8 rounded-lg shadow-sm">
        <h3 class="text-lg text-gray-900 mb-3">Experiencia 100% digital</h3>
        <p class="text-gray-700">Activación, bloqueo y seguimiento desde una app o portal personalizado</p>
      </div>

      <div class="bg-white p-8 rounded-lg shadow-sm">
        <h3 class="text-lg text-gray-900 mb-3">Mejor gestión de gastos corporativos</h3>
        <p class="text-gray-700">Simplificación de viáticos, compras y pagos operativos cont razabilidad total</p>
      </div>

      <div class="bg-white p-8 rounded-lg shadow-sm">
        <h3 class="text-lg text-gray-900 mb-3">Marca propia, mayor visibilidad</h3>
        <p class="text-gray-700">Emisión personalizada bajo los estándares de cada entidad emisora</p>
      </div>
    </div>
  </div>

  <!-- Images section -->
  <div class="px-8 mb-16">
    <div class="flex gap-6 justify-center">
      <div class="flex-1">
        <img src="/assets/images/Emision Imagen Izquierda.png" alt="Emisión Izquierda" class="w-full rounded-lg" loading="lazy">
      </div>
      <div class="flex-1">
        <img src="/assets/images/Emision Imagen Derecha.png" alt="Emisión Derecha" class="w-full rounded-lg" loading="lazy">
      </div>
    </div>
  </div>
</section>
