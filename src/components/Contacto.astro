---
import { Image } from 'astro:assets';
---

<section 
  class="w-full py-8 relative"
  style="background-image: url('/assets/images/Fondo%20form.png'); background-size: cover; background-position: center;"
  id="contacto"
>
  <!-- Dark overlay -->
  <div class="absolute inset-0 bg-black/60 pointer-events-none"></div>

  <div class="relative z-10">
    <div class="px-8 py-4">
      <div class="w-11/12 mx-auto">
        <div class="flex gap-0 items-stretch min-h-[480px]">
          <!-- Left side: Text overlay -->
          <div class="w-1/2 flex flex-col justify-center items-start pl-16">
            <div>
              <h2 class="text-5xl text-white mb-4">Hablemos.</h2>
              <p class="text-xl text-white">Construyamos una solución a tu medida.</p>
            </div>
          </div>

          <!-- Right side: Form -->
          <div class="w-1/2 px-16 py-1 flex flex-col justify-center creden-form-bg">
            <h3 class="text-1x1 text-center text-white mb-4">Agenda una reunión con nuestro equipo</h3>
        
        <form class="space-y-2">
          <input 
            type="text" 
            placeholder="Nombre*" 
            required
            class="w-full creden-form-input border-b border-gray-400 text-white placeholder-gray-300 pb-3 focus:outline-none focus:border-creden-green"
          />
          <input 
            type="text" 
            placeholder="Apellido*" 
            required
            class="w-full creden-form-input border-b border-gray-400 text-white placeholder-gray-300 pb-3 focus:outline-none focus:border-creden-green"
          />

          <input 
            type="email" 
            placeholder="Email*" 
            required
            class="w-full creden-form-input border-b border-gray-400 text-white placeholder-gray-300 pb-3 focus:outline-none focus:border-creden-green"
          />

          <input 
            type="text" 
            placeholder="País*" 
            required
            class="w-full creden-form-input border-b border-gray-400 text-white placeholder-gray-300 pb-3 focus:outline-none focus:border-creden-green"
          />

          <input 
            type="text" 
            placeholder="Empresa*" 
            required
            class="w-full creden-form-input border-b border-gray-400 text-white placeholder-gray-300 pb-3 focus:outline-none focus:border-creden-green"
          />

          <textarea 
            placeholder="¿Qué solución podemos ofrecerle a tu negocio?*" 
            required
            rows="4"
            class="w-full creden-form-input border-b border-gray-400 text-white placeholder-gray-300 pb-3 focus:outline-none focus:border-creden-green resize-none"
          ></textarea>

          <div class="pt-3">
            <button 
              type="submit"
              class="w-2/6 creden-form-btn text-white py-1 rounded-4xl hover:opacity-90 transition-opacity"
            >
              Enviar
            </button>
          </div>
        </form>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
