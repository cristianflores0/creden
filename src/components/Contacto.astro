<section
  class="relative w-full py-8"
  style="background-image: url('/assets/images/Fondo%20form.png'); background-size: cover; background-position: center;"
  id="contacto"
>
  <div class="pointer-events-none absolute inset-0 bg-black/60"></div>

  <div class="relative z-10">
    <div class="px-8 py-4">
      <div class="mx-auto w-11/12">
        <div class="flex min-h-[480px] items-stretch gap-0">
          <div class="flex w-1/2 flex-col items-start justify-center pl-16">
            <div>
              <h2 class="mb-4 text-5xl text-white">Hablemos.</h2>
              <p class="text-xl text-white">Construyamos una solucion a tu medida.</p>
            </div>
          </div>

          <div class="creden-form-bg flex w-1/2 flex-col justify-center px-16 py-6">
            <h3 class="mb-4 text-center text-white">Agenda una reunion con nuestro equipo</h3>

            <form
              id="contact-form"
              class="space-y-2"
              action="https://formspree.io/f/xzdykypp"
              method="POST"
            >
              <input
                type="text"
                name="nombre"
                placeholder="Nombre*"
                required
                class="creden-form-input w-full border-b border-gray-400 pb-3 text-white placeholder-gray-300 focus:border-creden-green focus:outline-none"
              />
              <input
                type="text"
                name="apellido"
                placeholder="Apellido*"
                required
                class="creden-form-input w-full border-b border-gray-400 pb-3 text-white placeholder-gray-300 focus:border-creden-green focus:outline-none"
              />

              <input
                type="email"
                name="email"
                placeholder="Email*"
                required
                class="creden-form-input w-full border-b border-gray-400 pb-3 text-white placeholder-gray-300 focus:border-creden-green focus:outline-none"
              />

              <input
                type="text"
                name="pais"
                placeholder="Pais*"
                required
                class="creden-form-input w-full border-b border-gray-400 pb-3 text-white placeholder-gray-300 focus:border-creden-green focus:outline-none"
              />

              <input
                type="text"
                name="empresa"
                placeholder="Empresa*"
                required
                class="creden-form-input w-full border-b border-gray-400 pb-3 text-white placeholder-gray-300 focus:border-creden-green focus:outline-none"
              />

              <textarea
                name="mensaje"
                placeholder="Que solucion podemos ofrecerle a tu negocio?*"
                required
                rows="4"
                class="creden-form-input w-full resize-none border-b border-gray-400 pb-3 text-white placeholder-gray-300 focus:border-creden-green focus:outline-none"
              ></textarea>

              <input type="hidden" name="_subject" value="Nuevo contacto desde Credencial Web" />

              <p
                id="contact-form-status"
                class="min-h-6 text-sm text-white/90"
                aria-live="polite"
              ></p>

              <div class="pt-3">
                <button
                  id="contact-form-submit"
                  type="submit"
                  class="creden-form-btn w-2/6 rounded-4xl py-1 text-white transition-opacity hover:opacity-90 disabled:cursor-not-allowed disabled:opacity-60"
                >
                  Enviar
                </button>
              </div>
            </form>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script is:inline>
  const form = document.querySelector('#contact-form');
  const status = document.querySelector('#contact-form-status');
  const submitButton = document.querySelector('#contact-form-submit');

  if (form instanceof HTMLFormElement && status instanceof HTMLElement && submitButton instanceof HTMLButtonElement) {
    form.addEventListener('submit', async (event) => {
      event.preventDefault();

      status.textContent = 'Enviando mensaje...';
      status.classList.remove('text-red-300', 'text-green-300');
      submitButton.disabled = true;

      try {
        const response = await fetch(form.action, {
          method: 'POST',
          body: new FormData(form),
          headers: {
            Accept: 'application/json'
          }
        });

        const data = await response.json();

        if (!response.ok) {
          const errorMessage = Array.isArray(data.errors) && data.errors.length > 0
            ? data.errors.map((item) => item.message).join(' ')
            : 'No pudimos enviar el formulario.';

          throw new Error(errorMessage);
        }

        form.reset();
        status.textContent = 'Gracias por escribirnos. Te responderemos pronto.';
        status.classList.add('text-green-300');
      } catch (error) {
        const message = error instanceof Error ? error.message : 'Ocurrio un error inesperado.';
        status.textContent = message;
        status.classList.add('text-red-300');
      } finally {
        submitButton.disabled = false;
      }
    });
  }
</script>
